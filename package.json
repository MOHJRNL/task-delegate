{
  "name": "task-delegate",
  "version": "2.1.0",
  "description": "One portable delegation interface for discovering and dispatching bounded tasks to CLI coding agents with manual review and normalized results.",
  "type": "module",
  "bin": {
    "task-delegate": "bin/task-delegate.mjs"
  },
  "scripts": {
    "check": "node scripts/check-syntax.mjs",
    "test": "node --test test/*.test.mjs",
    "dry-run": "node bin/task-delegate.mjs run --backend opencode --mode plan --brief examples/brief.sample.md --cd . --dry-run --allow-dirty",
    "start": "node bin/task-delegate.mjs --help",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run check && npm test && npm run pack:dry-run",
    "doctor": "node bin/task-delegate.mjs doctor",
    "list-backends": "node bin/task-delegate.mjs list-backends",
    "init-brief": "node bin/task-delegate.mjs init-brief --out task-delegate.brief.md --force",
    "targets": "node bin/task-delegate.mjs targets",
    "delegate:dry-run": "node bin/task-delegate.mjs delegate --to opencode --task \"Dry-run delegation\" --cd . --dry-run --allow-dirty",
    "verify": "node skills/task-delegate/scripts/manage.mjs verify",
    "verify:live": "node skills/task-delegate/scripts/manage.mjs verify --live",
    "setup": "node skills/task-delegate/scripts/manage.mjs setup"
  },
  "keywords": [
    "agent-skills",
    "antigravity",
    "claude-code",
    "codex",
    "coding-agent",
    "delegation",
    "grok",
    "kimi",
    "low-context",
    "multi-agent",
    "opencode",
    "zai"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.17.0"
  },
  "devDependencies": {},
  "files": [
    "bin/",
    "skills/",
    "examples/",
    "AGENTS.md",
    "README.md",
    "LICENSE",
    "skills.sh.json",
    "PUBLISHING.md",
    "NOTICE",
    "scripts/check-syntax.mjs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MOHJRNL/task-delegate.git"
  },
  "bugs": {
    "url": "https://github.com/MOHJRNL/task-delegate/issues"
  },
  "homepage": "https://github.com/MOHJRNL/task-delegate#readme",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./skill": "./skills/task-delegate/SKILL.md",
    "./package.json": "./package.json"
  },
  "author": "Noah Hendy"
}
