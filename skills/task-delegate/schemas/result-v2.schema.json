{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MOHJRNL/task-delegate/schemas/result-v2.schema.json",
  "title": "TaskDelegate Result v2",
  "type": "object",
  "required": ["schemaVersion", "status", "target", "mode", "reviewRequired", "commitAllowed"],
  "properties": {
    "schemaVersion": { "const": "task-delegate.result.v2" },
    "status": { "enum": ["completed", "failed", "refused"] },
    "target": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["manual", "plan"] },
    "changedFiles": { "type": "array", "items": { "type": "string" } },
    "reviewRequired": { "const": true },
    "commitAllowed": { "const": false }
  },
  "additionalProperties": true
}
